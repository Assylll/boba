# Local/dev default (file storage)
STATE_STORAGE=file
STATE_DATA_DIR=./data
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin12345
BOBA_POS_SESSION_SECRET=change_me_long_random_secret

# Persistent Vercel storage (recommended):
# STATE_STORAGE=redis
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
# Or Vercel-style aliases (equivalent):
# KV_REST_API_URL=https://...upstash.io
# KV_REST_API_TOKEN=...
# Optional custom key:
# STATE_REDIS_KEY=boba-pos:state:global
